# ==============================================================================
# Mafia Telegram Bot - Environment Configuration
# Copy this file to `.env` and fill in the values.
# ==============================================================================

# --- Telegram ---
# Obtain a token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Optional proxy for reaching the Telegram API (useful where Telegram is
# blocked). Leave it UNSET/commented to connect directly with no proxy.
# Supported schemes: socks5, socks4, http, https. SOCKS requires the
# 'aiohttp-socks' package (already in requirements.txt).
#   Examples:
#     BOT_PROXY=socks5://127.0.0.1:10808
#     BOT_PROXY=http://user:pass@127.0.0.1:8080
# BOT_PROXY=


# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mafia
POSTGRES_PASSWORD=mafia
POSTGRES_DB=mafia

# --- Redis (FSM storage) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Application ---
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Render logs as pretty console output (true) or JSON (false)
LOG_CONSOLE=true
# Environment name: development / production
ENVIRONMENT=development
