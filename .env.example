# ==============================================================================
# Mafia Telegram Bot - Environment Configuration
# Copy this file to `.env` and fill in the values.
# ==============================================================================

# --- Telegram ---
# Obtain a token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Optional: numeric Telegram user id of the bot owner. When set, this user sees
# an extra owner-only «🧪 تست کامل بازی» button (and the /owner_test command)
# that runs a full end-to-end self-test of the game pipeline. Leave UNSET to
# disable the feature entirely (no one can access it).
#   Example: BOT_OWNER_ID=123456789
# BOT_OWNER_ID=6902896086


# Optional proxy for reaching the Telegram API (useful where Telegram is
# blocked). Leave it UNSET/commented to connect directly with no proxy.
# Supported schemes: socks5, socks4, http, https. SOCKS requires the
# 'aiohttp-socks' package (already in requirements.txt).
#   Examples:
#     BOT_PROXY=socks5://127.0.0.1:10808
#     BOT_PROXY=http://user:pass@127.0.0.1:8080
# BOT_PROXY=


# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mafia
POSTGRES_PASSWORD=mafia
POSTGRES_DB=mafia
# Connection-pool sizing. Small defaults keep RAM low on tiny hosts (each PG
# connection is a separate backend process). Raise for high-traffic servers.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5


# --- Redis (FSM storage + Mini App live-state/pub-sub) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Application ---
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Render logs as pretty console output (true) or JSON (false)
LOG_CONSOLE=true
# Environment name: development / production
ENVIRONMENT=development


# --- Telegram Mini App (online voice-table client) ---
# Public HTTPS URL where the compiled Mini App frontend is served. Telegram only
# opens Mini Apps over HTTPS, so this must be a real https:// origin (front the
# `miniapp` service with a TLS-terminating reverse proxy such as Caddy/Nginx).
# Leave UNSET to hide the «📱 میز آنلاین» launch button and relax CORS locking.
#   Example: MINIAPP_URL=https://mafia.example.com
# MINIAPP_URL=

# Bind address/port for the uvicorn Mini App server (see docker-compose `miniapp`).
MINIAPP_HOST=0.0.0.0
MINIAPP_PORT=8080

# Default speaking timer per turn (seconds) and challenge/defense duration.
MINIAPP_SPEAKING_SECONDS=60
MINIAPP_CHALLENGE_SECONDS=30
